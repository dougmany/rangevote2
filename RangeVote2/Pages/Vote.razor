@page "/vote"
@attribute [Authorize]

<PageTitle>@decisionName - Graze - range.vote</PageTitle>

@using RangeVote2.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@inject IRangeVoteRepository Repository
@inject IVoteChainService ChainService
@inject INeedsMapService NeedsMapService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime

@if (isLoading)
{
    <p><em>Loading the pasture...</em></p>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">@errorMessage</div>
    <a href="/decisions" class="btn btn-secondary">Back to Pastures</a>
}
else if (choices.Any())
{
    <div class="mb-4">
        <h1>🌾 @decisionName</h1>

        @if (!string.IsNullOrWhiteSpace(decisionDescription))
        {
            <p class="text-muted">@decisionDescription</p>
        }

        @if (!string.IsNullOrWhiteSpace(nm_citizen) && needTagIds.Length > 0)
        {
            <div class="alert alert-info d-flex align-items-center gap-2">
                <span>🗺️</span>
                <span>
                    You arrived from <strong>needs.vote</strong>. Your need-tag will be attached to your vote
                    @if (!string.IsNullOrWhiteSpace(needsMapPolicyAreaSlug))
                    {
                        <span> for policy area <strong>@needsMapPolicyAreaSlug</strong></span>
                    }
                    .
                </span>
            </div>
        }

        @if (isClosed)
        {
            <div class="alert alert-warning">This pasture is fenced off. No more grazing allowed!</div>
        }
        else if (closeDate.HasValue)
        {
            <div class="alert alert-info">Grazing closes on @closeDate.Value.ToString("MMMM dd, yyyy") - munch while you can!</div>
        }
    </div>

    <div class="d-flex gap-2 align-items-center mb-3">
        <label class="fw-semibold mb-0" for="ballot-search">Filter</label>
        <input id="ballot-search"
               class="form-control"
               style="max-width: 320px;"
               placeholder="Filter by name or description"
               value="@searchText"
               @oninput="OnSearchInput"
               aria-label="Filter ballots" />
    </div>

    <div class="vote-layout">
        @* Left Pane: Voting List *@
        <div class="vote-list-pane">
            @{
                var filteredChoices = FilteredChoices.OrderByDescending(t => t.Score).ToList();
            }

            @if (!filteredChoices.Any())
            {
                <div class="text-muted">No ballots match your filter.</div>
            }
            else
            {
                @foreach (var choice in filteredChoices)
                {
                    var rank = GetRank(choice.Id);
                    var isSelected = choice.Id == selectedChoiceId;

                    <div class="vote-list-item @(isSelected ? "selected" : "")"
                         @onclick="@(() => SelectChoice(choice.Id))">

                        @* Rank Badge *@
                        <div class="vote-rank-badge rank-@rank">
                            #@rank
                        </div>

                        @* Thumbnail *@
                        @if (!string.IsNullOrWhiteSpace(choice.ImageLink))
                        {
                            <img src="@choice.ImageLink" alt="@choice.Name" class="vote-item-thumbnail" />
                        }

                        @* Content *@
                        <div class="vote-item-content">
                            <div class="vote-item-name">@choice.Name</div>
                            @if (!string.IsNullOrWhiteSpace(choice.Description))
                            {
                                <div class="vote-item-description">@choice.Description</div>
                            }
                        </div>

                        @* Compact Controls *@
                        @if (!isClosed)
                        {
                            <div class="vote-item-controls" @onclick:stopPropagation="true">
                                <button class="vote-btn-compact vote-btn-down"
                                        @onclick="@(() => DecrementScore(choice.Id, 10))"
                                        title="Much less tasty!">−−</button>
                                <button class="vote-btn-compact vote-btn-down-small"
                                        @onclick="@(() => DecrementScore(choice.Id, 1))"
                                        title="Slightly less tasty">−</button>
                                <span class="vote-score-compact">@((choice.Score / 10.0).ToString("N1"))</span>
                                <button class="vote-btn-compact vote-btn-up-small"
                                        @onclick="@(() => IncrementScore(choice.Id, 1))"
                                        title="Slightly tastier">+</button>
                                <button class="vote-btn-compact vote-btn-up"
                                        @onclick="@(() => IncrementScore(choice.Id, 10))"
                                        title="Much tastier!">++</button>
                            </div>
                        }
                        else
                        {
                            <span class="vote-score-compact">@((choice.Score / 10.0).ToString("N1"))</span>
                        }
                    </div>
                }
            }
        </div>

        @* Right Pane: Detail View *@
        @if (SelectedChoice != null)
        {
            <div class="vote-detail-pane">
                <div class="vote-detail-header">
                    @if (!string.IsNullOrWhiteSpace(SelectedChoice.ImageLink))
                    {
                        <img src="@SelectedChoice.ImageLink" alt="@SelectedChoice.Name" class="vote-detail-image" />
                    }
                    else
                    {
                        <div class="vote-detail-image-placeholder">🌾</div>
                    }
                    <div class="vote-detail-rank">
                        @if (GetRank(SelectedChoice.Id) == 1) { <span>🥇</span> }
                        else if (GetRank(SelectedChoice.Id) == 2) { <span>🥈</span> }
                        else if (GetRank(SelectedChoice.Id) == 3) { <span>🥉</span> }
                        #@GetRank(SelectedChoice.Id)
                    </div>
                    <div class="vote-detail-score-overlay">@((SelectedChoice.Score / 10.0).ToString("N1"))</div>
                </div>

                <div class="vote-detail-body">
                    <h2 class="vote-detail-name">@SelectedChoice.Name</h2>

                    @if (!string.IsNullOrWhiteSpace(SelectedChoice.Description))
                    {
                        <div class="vote-detail-description">@SelectedChoice.Description</div>
                    }

                    @if (!isClosed)
                    {
                        <div class="vote-detail-controls">
                            <button class="vote-btn vote-btn-down"
                                    @onclick="@(() => DecrementScore(SelectedChoice.Id, 10))"
                                    title="Much less tasty!">
                                <span>−−</span>
                            </button>
                            <button class="vote-btn vote-btn-down-small"
                                    @onclick="@(() => DecrementScore(SelectedChoice.Id, 1))"
                                    title="Slightly less tasty">
                                <span>−</span>
                            </button>
                            <button class="vote-btn vote-btn-up-small"
                                    @onclick="@(() => IncrementScore(SelectedChoice.Id, 1))"
                                    title="Slightly tastier">
                                <span>+</span>
                            </button>
                            <button class="vote-btn vote-btn-up"
                                    @onclick="@(() => IncrementScore(SelectedChoice.Id, 10))"
                                    title="Much tastier!">
                                <span>++</span>
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @if (message != null)
    {
        <div class="alert alert-info mt-3">@message</div>
    }

    @if (showReceipt && receiptViewModel != null)
    {
        <div class="card mt-4 border-success">
            <div class="card-body">
                <h5 class="card-title">Vote Receipt</h5>
                <p class="card-text">Your votes have been recorded and chained to the immutable ledger.</p>

                <div class="mb-3">
                    <label class="form-label fw-bold">Receipt Hash:</label>
                    <div class="d-flex align-items-center gap-2">
                        <code class="bg-light p-2 rounded flex-grow-1 text-break" style="font-size: 0.85rem;">@receiptViewModel.ReceiptHash</code>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CopyReceipt">Copy</button>
                    </div>
                </div>

                <p class="text-muted mb-1">
                    <strong>@receiptViewModel.BallotName</strong> &mdash;
                    @receiptViewModel.CandidatesVotedOn candidates scored at
                    @receiptViewModel.IssuedAt.ToString("g") UTC
                </p>
                <p class="text-muted small">
                    Save this receipt hash. You can use it to verify your vote was recorded correctly at any time.
                </p>

                @if (needsMapBuckets != null && needsMapBuckets.Length > 0)
                {
                    <div class="alert alert-success mt-3 mb-0">
                        <strong>🗺️ Needs Map</strong> — Your vote has been tagged with:
                        @foreach (var bucket in needsMapBuckets)
                        {
                            <span class="badge ms-1"
                                  style="background-color: @(bucket.ColorHex ?? "#6c757d"); color: white;">
                                @bucket.Name
                            </span>
                        }
                    </div>
                }

                <div class="d-flex gap-2 mt-3">
                    <a href="/audit?ballotId=@currentDecisionId" class="btn btn-outline-primary">Verify Chain Integrity</a>
                    <a href="/decisions" class="btn btn-primary">Back to Pastures</a>
                </div>
            </div>
        </div>
    }
    else if (!isClosed)
    {
        <div class="d-flex gap-2 mt-4">
            <a href="/decisions" class="btn btn-secondary btn-lg">Back to Pastures</a>
        </div>

        <button class="vote-fab" @onclick="RecordToChain" disabled="@isSaving"
                title="Record votes to the blockchain">
            @if (isSaving)
            {
                <span>...</span>
            }
            else
            {
                <span>🐄 Vote</span>
            }
        </button>
    }
    else
    {
        <div class="mt-4">
            <a href="/result?ballotId=@currentDecisionId" class="btn btn-primary">See The Digest 💩</a>
            <a href="/decisions" class="btn btn-secondary">Back to Pastures</a>
        </div>
    }
}

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public Guid? ballotId { get; set; }

    // Legacy support
    [Parameter]
    [SupplyParameterFromQuery]
    public String? electionId { get; set; }

    // Needs Map integration — populated when citizen arrives from needs.vote
    [Parameter]
    [SupplyParameterFromQuery(Name = "nm_citizen")]
    public string? nm_citizen { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "nm_tags")]
    public string? nm_tags { get; set; } // comma-separated need tag UUIDs

    private class VoteChoice
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public string? ImageLink { get; set; }
        public int Score { get; set; }
    }

    private List<VoteChoice> choices = new();
    Candidate[]? candidates; // For legacy
    String? message;
    String? errorMessage;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isClosed = false;
    private bool showReceipt = false;
    private VoteReceiptViewModel? receiptViewModel;
    private DateTime? closeDate;
    private string decisionName = "Graze";
    private string? decisionDescription;
    private Guid userId;
    private Guid currentDecisionId;
    private string searchText = "";

    // Needs Map — derived from URL params + ballot metadata
    private string[] needTagIds = Array.Empty<string>();
    private string? needsMapPolicyAreaSlug;
    private NeedsMapBucketInfo[]? needsMapBuckets; // returned from API after vote

    // Selection state for detail panel
    private Guid? selectedChoiceId = null;
    private VoteChoice? SelectedChoice => choices.FirstOrDefault(c => c.Id == selectedChoiceId);
    private IEnumerable<VoteChoice> FilteredChoices => string.IsNullOrWhiteSpace(searchText)
        ? choices
        : choices.Where(c =>
            (!string.IsNullOrWhiteSpace(c.Name) && c.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrWhiteSpace(c.Description) && c.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null)
            {
                userId = Guid.Parse(userIdClaim.Value);
            }
        }

        try
        {
            // New decision system
            if (ballotId.HasValue)
            {
                currentDecisionId = ballotId.Value;
                await LoadDecision();
            }
            // Legacy system
            else if (!string.IsNullOrWhiteSpace(electionId))
            {
                await LoadLegacyBallot();
            }
            else
            {
                errorMessage = "No pasture specified. Where should we graze?";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading pasture: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDecision()
    {
        // Get decision metadata
        var decision = await Repository.GetBallotMetadataAsync(currentDecisionId);
        if (decision == null)
        {
            errorMessage = "Pasture not found. Maybe the cows ate it all?";
            return;
        }

        // Check permissions
        var canVote = await Repository.CanUserVoteAsync(currentDecisionId, userId);
        if (!canVote)
        {
            errorMessage = "You're not allowed to graze on this pasture. Mooo-ve along!";
            return;
        }

        decisionName = decision.Name;
        decisionDescription = decision.Description;
        isClosed = decision.Status == BallotStatus.Closed;
        closeDate = decision.CloseDate;
        needsMapPolicyAreaSlug = decision.NeedsMapPolicyAreaSlug;

        // Parse Needs Map URL parameters
        if (!string.IsNullOrWhiteSpace(nm_tags))
            needTagIds = nm_tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        // Get choices
        var decisionChoices = await Repository.GetCandidatesAsync(currentDecisionId);

        // Get existing votes
        var existingVotes = await Repository.GetUserVotesAsync(currentDecisionId, userId);

        // DEBUG: Show vote count
        if (existingVotes.Any())
        {
            message = $"Loaded {existingVotes.Count} existing votes";
        }

        // Build choice list with scores
        foreach (var choice in decisionChoices)
        {
            var existingVote = existingVotes.FirstOrDefault(v => v.CandidateId == choice.Id);
            choices.Add(new VoteChoice
            {
                Id = choice.Id,
                Name = choice.Name,
                Description = choice.Description,
                ImageLink = choice.ImageLink,
                Score = existingVote?.Score ?? 50 // Default to 50 (5.0)
            });
        }

        // Auto-select first item (highest score)
        if (choices.Any())
        {
            selectedChoiceId = choices.OrderByDescending(c => c.Score).First().Id;
        }
    }

    private async Task LoadLegacyBallot()
    {
        if (electionId == null) return;

        decisionName = electionId;
        var ballot = await Repository.GetBallotAsync(userId, electionId);
        candidates = ballot.Candidates;
    }

    void SelectChoice(Guid id)
    {
        selectedChoiceId = id;
        StateHasChanged();
    }

    void OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? string.Empty;
        EnsureSelectionWithinFilter();
    }

    void EnsureSelectionWithinFilter()
    {
        var filtered = FilteredChoices.OrderByDescending(c => c.Score).ToList();

        if (!filtered.Any())
        {
            selectedChoiceId = null;
            return;
        }

        if (selectedChoiceId == null || !filtered.Any(c => c.Id == selectedChoiceId))
        {
            selectedChoiceId = filtered.First().Id;
        }
    }

    int GetRank(Guid choiceId)
    {
        return choices.OrderByDescending(c => c.Score)
                      .ToList()
                      .FindIndex(c => c.Id == choiceId) + 1;
    }

    async Task IncrementScore(Guid choiceId, int amount)
    {
        var choice = choices.FirstOrDefault(c => c.Id == choiceId);
        if (choice != null && choice.Score < 99)
        {
            choice.Score = Math.Min(99, choice.Score + amount);
            await SaveScoresLocally();
        }
    }

    async Task DecrementScore(Guid choiceId, int amount)
    {
        var choice = choices.FirstOrDefault(c => c.Id == choiceId);
        if (choice != null && choice.Score > 0)
        {
            choice.Score = Math.Max(0, choice.Score - amount);
            await SaveScoresLocally();
        }
    }

    async Task SaveScoresLocally()
    {
        if (!ballotId.HasValue) return;
        try
        {
            var scores = choices.ToDictionary(c => c.Id, c => c.Score);
            await Repository.SaveVotesAsync(currentDecisionId, userId, scores);
        }
        catch (Exception ex)
        {
            message = $"Error saving: {ex.Message}";
        }
    }

    async Task RecordToChain()
    {
        if (isClosed)
        {
            message = "This pasture is fenced off!";
            return;
        }

        try
        {
            isSaving = true;
            message = "Recording to the chain...";

            if (ballotId.HasValue)
            {
                var scores = choices.ToDictionary(c => c.Id, c => c.Score);
                await Repository.SaveVotesAsync(currentDecisionId, userId, scores);

                receiptViewModel = await ChainService.RecordVotesAndGetReceiptAsync(
                    currentDecisionId, userId, scores, decisionName);
                showReceipt = true;
                isSaving = false;
                message = null;

                // Notify Needs Map if citizen arrived from needs.vote with need-tags
                if (!string.IsNullOrWhiteSpace(nm_citizen) &&
                    needTagIds.Length > 0 &&
                    !string.IsNullOrWhiteSpace(needsMapPolicyAreaSlug))
                {
                    needsMapBuckets = await NeedsMapService.SendNeedTagAsync(
                        nm_citizen,
                        receiptViewModel.ReceiptHash,
                        needsMapPolicyAreaSlug,
                        needTagIds,
                        receiptViewModel.IssuedAt);
                }
            }
            else if (!string.IsNullOrWhiteSpace(electionId) && candidates != null)
            {
                await Repository.PutBallotAsync(new Ballot { Id = userId, Candidates = candidates }, electionId);
                NavigationManager.NavigateTo("/decisions");
            }
        }
        catch (Exception ex)
        {
            message = $"Error recording: {ex.Message}";
            isSaving = false;
        }
    }

    async Task CopyReceipt()
    {
        if (receiptViewModel != null)
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", receiptViewModel.ReceiptHash);
            message = "Receipt hash copied to clipboard!";
        }
    }
}
